                {
                  "id": "5e3de85a-6661-4787-a0cf-c026d873b5a5",
                  "title": "Expedition",
                  "status": "Mitigated",
                  "severity": "Critical",
                  "type": "Tampering",
                  "description": "See OWASP Automated Threat #6:\nUsing speed to violate explicit or implicit assumptions about the application’s normal use to achieve unfair individual gain",
                  "mitigation": "User requests are received for execution one at a time and cannot lead to a race condition. Until the first transaction completes, the second one will not be able to start.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 15,
                  "score": ""
                },
                {
                  "id": "7ab4940c-40ee-4f56-a19c-fed2969ab5df",
                  "title": "Denial of Service",
                  "status": "Mitigated",
                  "severity": "Critical",
                  "type": "Denial of service",
                  "description": "See OWASP Automated Threat #15:\nUsage may resemble legitimate application usage but leads to exhaustion of resources",
                  "mitigation": "Each transaction occurs in a specific context, which cannot allow it to be executed for longer than specified in the service configuration.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 17,
                  "score": ""
                },
                {
                  "id": "8adcaccb-7bd3-4b1c-858f-801411b6d7b4",
                  "title": "Sniping",
                  "status": "Mitigated",
                  "severity": "Medium",
                  "type": "Elevation of privilege",
                  "description": "See OWASP Automated Threat #13:\nAutomated exploitation of system latencies in the form of timing attacks",
                  "mitigation": "The role model of the application does not differ for different users, therefore, there is no point in timing attacks to increase privileges.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 18,
                  "score": ""
